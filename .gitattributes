# Normalize all text files to LF in the repo; check out native on each OS.
# Keeps line endings consistent across Windows/macOS/Linux and silences the
# "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Explicitly treat common binary assets as binary (never normalized).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.mp4 binary
*.webm binary
