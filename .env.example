# ──────────────────────────────────────────────────────────────
# ShashankLearn — environment variables
# Copy this file to ".env" and fill in real values.
# Only VITE_* vars are exposed to the browser. Keep secrets OUT of here.
# ──────────────────────────────────────────────────────────────

# Supabase (Project Settings -> API)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Razorpay (client-side key id only — NEVER the secret here)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# ──────────────────────────────────────────────────────────────
# Server-only secrets below live in Supabase Edge Function env,
# NOT in this client .env. Listed here for documentation only.
# ──────────────────────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY=...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...
